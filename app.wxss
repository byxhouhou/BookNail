page {
  min-height: 100vh;
  background: #fff7f8;
  color: #2f292b;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx 28rpx 48rpx;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.muted {
  color: #8a7d80;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #a34d61;
  background: #ffe9ef;
  font-size: 24rpx;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 92rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #d75f7a;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 30rpx rgba(215, 95, 122, 0.2);
}

.primary-button.is-disabled {
  color: rgba(255, 255, 255, 0.8);
  background: #d8c5ca;
  box-shadow: none;
}
