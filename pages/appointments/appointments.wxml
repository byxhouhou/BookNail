<view class="page-shell appointments-page">
  <view class="summary">
    <view>
      <view class="summary-title">预约记录</view>
      <view class="summary-copy">查看所有已占用时段，自己的预约也会显示在这里。</view>
    </view>
    <view class="summary-count">{{appointments.length}}</view>
  </view>

  <view wx:if="{{appointments.length}}" class="appointment-list">
    <view wx:for="{{appointments}}" wx:key="id" class="appointment-item">
      <view class="appointment-main">
          <view>
            <view class="appointment-time">{{item.date}} {{item.time}}</view>
            <view class="appointment-service">{{item.serviceName}}</view>
            <view wx:if="{{item.priceLabel}}" class="appointment-price">预估：{{item.priceLabel}}</view>
          </view>
        <view class="status-tag">已预约</view>
      </view>
      <view class="appointment-detail">
        <text>{{item.name}}</text>
        <text>{{item.phone}}</text>
      </view>
      <view wx:if="{{item.note}}" class="appointment-note">{{item.note}}</view>
      <button wx:if="{{!item.isSeed}}" class="delete-button" bindtap="deleteAppointment" data-id="{{item.id}}">取消预约</button>
    </view>
  </view>

  <view wx:else class="empty-state">
    <view class="empty-title">暂无预约</view>
    <view class="empty-copy">返回预约页选择一个喜欢的时间吧。</view>
  </view>
</view>
