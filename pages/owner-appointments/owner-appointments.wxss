.owner-appointments-page {
  padding-bottom: 64rpx;
}

.manager-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 190rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2f7785 0%, #6fb5a8 58%, #e1b86d 100%);
}

.manager-title {
  font-size: 42rpx;
  font-weight: 800;
}

.manager-copy {
  max-width: 460rpx;
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.5;
  opacity: 0.9;
}

.manager-count {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 112rpx;
  height: 112rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.55);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  font-size: 42rpx;
  font-weight: 800;
}

.manager-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.outline-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border: 2rpx solid #d75f7a;
  border-radius: 8rpx;
  color: #d75f7a;
  background: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
}

.outline-button.danger {
  border-color: #8a7d80;
  color: #5f5356;
}

.rest-panel {
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.date-scroll {
  width: 100%;
  white-space: nowrap;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 124rpx;
  margin-right: 16rpx;
  border: 2rpx solid #f3dde2;
  border-radius: 8rpx;
  background: #ffffff;
}

.date-item.active {
  border-color: #d75f7a;
  color: #d75f7a;
  background: #fff0f4;
}

.date-week {
  font-size: 24rpx;
  color: #8a7d80;
}

.date-day {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.rest-time-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin: 22rpx 0;
}

.rest-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.rest-action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 86rpx;
  border: 2rpx solid #d75f7a;
  border-radius: 8rpx;
  color: #d75f7a;
  background: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.rest-action-button.primary {
  color: #ffffff;
  background: #d75f7a;
}

.rest-action-button.danger {
  border-color: #d75f7a;
  color: #d75f7a;
  background: #fff0f4;
}

.rest-action-button.secondary {
  border-color: #2f7785;
  color: #2f7785;
  background: #f1fbfa;
}

.rest-time-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border: 2rpx solid #f1dce2;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.rest-time-slot.active {
  border-color: #d75f7a;
  color: #ffffff;
  background: #d75f7a;
}

.rest-time-slot.booked {
  color: #9e9295;
  border-color: #e5dadd;
  background: #eee8ea;
}

.rest-time-slot.booked.active {
  color: #d75f7a;
  border-color: #d75f7a;
  background: #fff7f8;
}

.slot-status {
  margin-top: 8rpx;
  font-size: 21rpx;
  font-weight: 500;
}

.appointment-list {
  margin-top: 26rpx;
}

.appointment-item {
  margin-bottom: 20rpx;
  padding: 26rpx;
  border-radius: 8rpx;
  background: #ffffff;
}

.appointment-item.rest-item {
  background: #f7fbfb;
}

.appointment-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.appointment-time {
  font-size: 32rpx;
  font-weight: 800;
}

.appointment-service {
  margin-top: 10rpx;
  color: #d75f7a;
  font-size: 26rpx;
  font-weight: 700;
}

.appointment-price {
  margin-top: 8rpx;
  color: #5f5356;
  font-size: 24rpx;
  font-weight: 700;
}

.status-tag {
  flex: 0 0 auto;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  color: #2f7785;
  background: #e8f5f3;
  font-size: 23rpx;
}

.status-tag.rest {
  color: #7a5a20;
  background: #fff3d7;
}

.info-row {
  display: flex;
  gap: 18rpx;
  margin-top: 16rpx;
  color: #5f5356;
  font-size: 26rpx;
}

.info-label {
  flex: 0 0 140rpx;
  color: #8a7d80;
}

.appointment-note {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  color: #6f6366;
  background: #fff7f8;
  font-size: 25rpx;
  line-height: 1.45;
}

.appointment-actions {
  margin-top: 20rpx;
}

.cancel-appointment-button,
.release-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 76rpx;
  border-radius: 8rpx;
  font-size: 27rpx;
  font-weight: 700;
}

.cancel-appointment-button {
  color: #ffffff;
  background: #d75f7a;
}

.release-button {
  color: #2f7785;
  background: #e8f5f3;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 420rpx;
  margin-top: 28rpx;
  border: 2rpx dashed #e9ccd4;
  border-radius: 8rpx;
  background: #ffffff;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 800;
}

.empty-copy {
  margin-top: 14rpx;
  color: #8a7d80;
}
